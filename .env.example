# App
APP_ENV=local
LOG_LEVEL=info
DRY_RUN=true
REAL_TRADING_ENABLED=false
# Phase 1 supports only "explicit". Future values may include risk_percent or fixed_usdt.
ORDER_SIZING_MODE=explicit
DEFAULT_MARGIN_MODE=isolated
MAX_LEVERAGE=20
CONFIRMATION_TTL_SECONDS=300
# Trailing stop-loss monitor (percent of entry). Both must be > 0 to enable it;
# leave blank to disable. e.g. ACTIVATE=1 GAP=1 -> start trailing at +1% profit,
# keeping the stop 1% of entry behind the mark (floored at break-even).
TRAIL_ACTIVATE_PCT=
TRAIL_GAP_PCT=

# Realtime position gateway: polls open positions and pushes updates to the web
# SSE stream (GET /api/stream, gated by HTTP_STATUS_TOKEN) and trade-closed
# alerts to Telegram. Runs only when a live exchange is available (not dry-run).
REALTIME_ENABLED=true
REALTIME_POLL_SECONDS=3

# Autonomous campaign execution (/campaign). Explicit opt-in; ALSO requires
# BINANCE_TESTNET=true, REAL_TRADING_ENABLED=false, and DRY_RUN=false at runtime,
# so it can never place live-account orders. Keep false until testnet-validated.
CAMPAIGN_LIVE_ENABLED=false
# ACCESS_OPEN=true auto-approves everyone (free & open). false (default) =
# pre-launch gating: non-admin users get Home only + Request access; the admin
# (TELEGRAM_ADMIN_USER_ID) approves them to unlock the app.
ACCESS_OPEN=false
# PRIVATE_BETA=true (default) = invite-only: every approved crew member runs as
# Commander with UNLIMITED shared-server AI (the pioneer perk). Set PRIVATE_BETA=false
# at the public free launch to meter shared AI by tier (free/Crew = 10 AI runs/day)
# and let approved users fall back to their stored tier. BYO-key users are always
# free regardless. Requires AI_PROVIDER + AI_API_KEY below for shared AI to work.
PRIVATE_BETA=true

# Telegram
TELEGRAM_BOT_TOKEN=
# Bot @username (without @). Enables the one-click "Log in with Telegram" button
# on the web dashboard. The bot's domain must be set in BotFather (/setdomain)
# to your public site for the widget to work — so it works once deployed (Fly),
# not on localhost.
TELEGRAM_BOT_USERNAME=
# Owner/admin Telegram numeric user id. Admin bypasses future subscription checks.
TELEGRAM_ADMIN_USER_ID=
# Optional private-MVP allowlist. For multi-user SaaS, non-admin access comes from MongoDB subscription state.
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_MODE=polling
PUBLIC_WEBHOOK_URL=
# Dashboard URL opened as a Telegram Mini App via the /app & /start button
WEBAPP_URL=
TELEGRAM_POLLING_BACKOFF_MIN_SECONDS=1
TELEGRAM_POLLING_BACKOFF_MAX_SECONDS=30

# Optional HTTP/Fiber
HTTP_ENABLED=false
HTTP_ADDR=:8080
# Bearer token for the detailed /status endpoint (operational/trading flags).
# Leave blank to disable /status entirely (returns 404). /healthz and /readyz
# stay public and expose no trading config.
HTTP_STATUS_TOKEN=

# Binance
# For multi-user SaaS, user exchange keys should be encrypted in MongoDB per user.
# These env keys are for owner/admin or single-user MVP only.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_FUTURES_BASE_URL=https://demo-fapi.binance.com
BINANCE_REQUEST_TIMEOUT_SECONDS=10
EXCHANGE_INFO_CACHE_TTL_SECONDS=900

# TradingView webhook alerts
# TradingView does not provide general market-data REST for this bot.
# Use alerts/webhooks to send signals into POST /tradingview/webhook.
TRADINGVIEW_ENABLED=false
TRADINGVIEW_WEBHOOK_SECRET=

# AI advisor
# Disabled by default. Use openai_compatible for OpenAI-compatible chat completions APIs.
AI_ENABLED=false
AI_PROVIDER=disabled
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_SYSTEM_PROMPT=
AI_REQUEST_TIMEOUT_SECONDS=20
AI_MIN_CONFIDENCE_PERCENT=70
# Multi-AI ensemble (panel vote). When set, this overrides the single provider
# above. JSON array of {name, provider, api_key, base_url, model}; provider is
# "anthropic" (Claude) or "openai_compatible" (DeepSeek, Qwen, OpenAI, …).
# Example:
# AI_PROVIDERS=[{"name":"claude","provider":"anthropic","api_key":"sk-ant-...","model":"claude-opus-4-8"},{"name":"deepseek","provider":"openai_compatible","api_key":"sk-...","base_url":"https://api.deepseek.com/v1","model":"deepseek-chat"}]
AI_PROVIDERS=
AI_ENSEMBLE_POLICY=majority
AI_ENSEMBLE_MIN_VOTES=0
AI_AUTOTRADE_ENABLED=false

# Market-data enrichment (free Binance Futures order-flow injected into the AI
# prompt: funding, open interest, long/short ratio, taker buy/sell). Defaults on
# whenever AI is enabled. Uses the production market-data host even on testnet —
# these endpoints are public, read-only, and need no API key.
MARKETDATA_ENABLED=true
MARKETDATA_BASE_URL=https://fapi.binance.com
# Sampling window for the ratio endpoints: 5m,15m,30m,1h,2h,4h,6h,12h,1d
MARKETDATA_PERIOD=5m
# Candle interval for EMA/RSI/MACD technical indicators (1m,5m,15m,1h,4h,1d,...)
MARKETDATA_KLINE_INTERVAL=1h
# Crypto Fear & Greed Index sentiment (free, key-less). Defaults on with AI.
FEAR_GREED_ENABLED=true
FEAR_GREED_BASE_URL=https://api.alternative.me
# NewsAPI headlines (free tier). Added to the AI prompt only when a key is set.
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2

# MongoDB Atlas
MONGODB_URI=
MONGODB_DATABASE=tradebot

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# S3-compatible object storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Per-user Binance credential encryption (multi-tenant).
# Master key for sealing user API keys at rest (AES-256-GCM).
# Must be base64 of exactly 32 bytes, e.g.: openssl rand -base64 32
# Leave blank to keep multi-tenant credential storage disabled.
CREDENTIAL_ENCRYPTION_KEY=
# Identifier recorded with each sealed value so keys can be rotated.
CREDENTIAL_ENCRYPTION_KEY_ID=v1

# Session JWT signing (base64, >= 32 bytes): openssl rand -base64 32
# Empty disables session tokens (login still works but returns no token).
AUTH_JWT_SECRET=
AUTH_JWT_TTL_SECONDS=86400
